# Copy to `.env` in this folder (website/). Vite reads `.env`, not this file.
# Supabase: Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_OR_ANON_KEY

# Edge Function secrets (Supabase Dashboard → Edge Functions → Secrets only):
# OPENAI_API_KEY (OpenAI platform keys only), ANTHROPIC_API_KEY, GEMINI_API_KEY, PERPLEXITY_API_KEY
# OpenRouter (sk-or-... keys): OPENROUTER_API_KEY, or put the key in OPENAI_API_KEY and/or ANTHROPIC_API_KEY (Claude auto-routed).
# Optional: OPENAI_MODEL, OPENROUTER_MODEL, OPENROUTER_ANTHROPIC_MODEL (e.g. anthropic/claude-3-5-haiku-20241022), OPENROUTER_HTTP_REFERER, OPENROUTER_APP_TITLE
# Optional: ANTHROPIC_MODEL, GEMINI_MODEL, PERPLEXITY_MODEL
